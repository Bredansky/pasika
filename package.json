{
  "name": "pasika",
  "version": "0.1.1",
  "description": "Reusable agent setup package",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bredansky/pasika"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rm -rf dist AGENTS.md CLAUDE.md && tsc -p tsconfig.json && npx vulyk docs",
    "check": "npm run lint && npm run typecheck",
    "fix": "eslint . --fix",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "bin": {
    "pasika": "dist/scripts/pasika.js"
  },
  "files": [
    "claude",
    "docs",
    "dist",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "vulyk": "github:Bredansky/vulyk#1ffc64cfa907719b076f0cb4b1a72c5c200f93a4",
    "zirka": "^0.0.28"
  }
}
